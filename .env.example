# Copier vers .env.local et remplir.

# --- SUPABASE : préférer le SESSION POOLER pour Vercel (IPv4 friendly) ---
# Connect → Method : Session pooling → URI
# Exemple (remplace REGION, PROJECT_REF, MOT_DE_PASSE) :
# DATABASE_URL="postgresql://postgres.bktvlflxqyoporazzzwo:MOT_DE_PASSE@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
#
# Transaction pooler (port 6543) peut échouer depuis certains réseaux :
# DATABASE_URL="postgresql://postgres:MOT_DE_PASSE@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&sslmode=require"

DATABASE_URL="postgresql://postgres.votre_ref:MOT_DE_PASSE@aws-0-VOTRE_REGION.pooler.supabase.com:5432/postgres"

# Après un déploiement, si /dashboard renvoie une erreur Prisma sur event.findMany :
# exécute prisma/supabase-hotfix-dashboard-500.sql dans Supabase (colonne instructionsBlocks + Checklist).

AUTH_SECRET="generer-avec-openssl-rand-base64-32"

# Local : même URL que dans le navigateur (évite les blocages CSRF des Server Actions).
# Ex. http://localhost:3000 ou http://127.0.0.1:3001 si tu utilises -p 3001
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Après avoir copié ce fichier vers .env.local :
#   npm run db:seed
# pour créer demo@reliz.app / demo1234 (voir prisma/seed.ts).

# Optionnel : cookie session « Secure » (défaut = auto : https si NEXT_PUBLIC_APP_URL
# commence par https://, ou déploiement Vercel). En prod auto-hébergée en HTTP :
# COOKIE_SECURE="false"

# Si la connexion / formulaires « ne font rien » (Host ≠ Origin : CDN, domaine custom, www) :
# liste séparée par des virgules, domaines en minuscules. Exemple :
# SERVER_ACTIONS_ALLOWED_ORIGINS="mondomaine.fr,www.mondomaine.fr,*.mondomaine.fr"

# Auto-hébergé sans URL « locale » dans NEXT_PUBLIC_APP_URL : désactive l’ajout des origines
# localhost dans la config build (rare). Valeur : 1
# SERVER_ACTIONS_STRICT_LOCAL="1"
